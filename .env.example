# ─────────────────────────────────────────────────────────────
# LMS SaaS — environment template. Copy to .env and fill in.
# Never commit real secrets. Production secrets live in Vercel /
# GitHub Actions secrets.
# ─────────────────────────────────────────────────────────────

NODE_ENV=development

# ── Tenancy ──────────────────────────────────────────────────
# pool  = shared DB, isolated by tenant_id + Postgres RLS
# silo  = dedicated DB (Neon project/branch) per tenant
# hybrid= pool by default; selected tenants promoted to silo
TENANT_MODE=hybrid
DEFAULT_TENANT_TIER=pool

# ── Database (Supabase — managed Postgres) ───────────────────
# Pooled connection (Supavisor / PgBouncer) for serverless + IPv4 runtimes.
# The direct db.<ref>.supabase.co host is IPv6-only; use the pooler URL
# (aws-<n>-<region>.pooler.supabase.com:6543?pgbouncer=true) for IPv4.
DATABASE_URL=postgresql://postgres.<ref>:password@aws-0-<region>.pooler.supabase.com:6543/postgres?pgbouncer=true&sslmode=require
# Direct connection for migrations (no pooler)
DIRECT_URL=postgresql://postgres:password@db.<ref>.supabase.co:5432/postgres?sslmode=require
# Control-plane DB that holds the tenant registry / silo routing
CONTROL_PLANE_DATABASE_URL=postgresql://postgres:password@db.<ref>.supabase.co:5432/postgres?sslmode=require

# Silo provisioning (optional). Provision dedicated DBs/branches per tenant via
# your managed Postgres provider's API (e.g. Neon) when promoting to silo tier.
NEON_API_KEY=
NEON_PROJECT_ID=

# ── Auth / Security ──────────────────────────────────────────
JWT_SECRET=change-me-in-prod
JWT_ISSUER=https://auth.lms.example.com
JWT_AUDIENCE=lms-api
ACCESS_TOKEN_TTL=900
REFRESH_TOKEN_TTL=2592000
# External CIAM directory (do NOT build your own IdP). Use a managed provider
# strong on SAML/OIDC SSO for institutions, e.g. WorkOS / Auth0 / Clerk.
# The identity service maps external identities -> internal users + claims.
CIAM_PROVIDER=workos
CIAM_API_KEY=
CIAM_CLIENT_ID=
OIDC_ISSUER_URL=

# ── Object storage (Vercel Blob) ─────────────────────────────
BLOB_READ_WRITE_TOKEN=

# ── Cache / queue / messaging (Upstash — serverless) ─────────
# Redis: tenant-prefixed keys (t:{tenantId}:...), LTI nonce/state cache,
# unread counters. QStash: serverless message bus + scheduled jobs (replaces
# Service Bus / Azure Functions / Hangfire).
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=
QSTASH_TOKEN=
QSTASH_CURRENT_SIGNING_KEY=
QSTASH_NEXT_SIGNING_KEY=

# ── Gateway rate limiting ────────────────────────────────────
# Per-tenant request budget per fixed window. Backed by Upstash Redis when the
# creds above are set (shared across gateway instances), else an in-process
# limiter. Exceeding the budget returns 429 with a Retry-After header.
RATE_LIMIT_MAX=600
RATE_LIMIT_WINDOW_SECONDS=60

# ── LLM (Groq) — used by analytics/AI (Lumi-equivalent) features ──
GROQ_API_KEY=
GROQ_MODEL=llama-3.3-70b-versatile

# ── Service URLs (gateway routing; ports 4000-4024) ──────────
GATEWAY_URL=http://localhost:4000
IDENTITY_URL=http://localhost:4001
TENANT_URL=http://localhost:4002
USER_ORG_URL=http://localhost:4003
ENROLLMENT_URL=http://localhost:4004
COURSE_URL=http://localhost:4005
CONTENT_URL=http://localhost:4006
ASSIGNMENT_URL=http://localhost:4007
ASSESSMENT_URL=http://localhost:4008
GRADING_URL=http://localhost:4009
DISCUSSION_URL=http://localhost:4010
ANNOUNCEMENT_URL=http://localhost:4011
NOTIFICATION_URL=http://localhost:4012
CALENDAR_URL=http://localhost:4013
RUBRIC_URL=http://localhost:4014
ANALYTICS_URL=http://localhost:4015
REPORTING_URL=http://localhost:4016
AI_URL=http://localhost:4017
LTI_URL=http://localhost:4018
SIS_URL=http://localhost:4019
VIDEO_URL=http://localhost:4020
SEARCH_URL=http://localhost:4021
BILLING_URL=http://localhost:4022
AUDIT_URL=http://localhost:4023
MOBILE_BFF_URL=http://localhost:4024

# ── Standards / Integrations (1EdTech) ───────────────────────
LTI_PLATFORM_ISSUER=https://lms.example.com
LTI_JWKS_URL=https://lms.example.com/.well-known/jwks.json
ONEROSTER_BASE_URL=https://lms.example.com/ims/oneroster/v1p2
CALIPER_ENDPOINT=https://lms.example.com/caliper/events
