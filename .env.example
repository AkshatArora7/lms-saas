# ─────────────────────────────────────────────────────────────
# LMS SaaS — environment template. Copy to .env and fill in.
# Never commit real secrets. Production secrets live in Vercel /
# GitHub Actions secrets.
# ─────────────────────────────────────────────────────────────

NODE_ENV=development

# ── Tenancy ──────────────────────────────────────────────────
# pool  = shared DB, isolated by tenant_id + Postgres RLS
# silo  = dedicated DB (Neon project/branch) per tenant
# hybrid= pool by default; selected tenants promoted to silo
TENANT_MODE=hybrid
DEFAULT_TENANT_TIER=pool

# ── Database ─────────────────────────────────────────────────
# LOCAL DOCKER: leave DATABASE_URL (and the other DB URLs below) EMPTY to use the
# bundled in-compose Postgres. docker-compose.yml interpolates each as
# ${DATABASE_URL:-<in-compose default>}, so ANY non-empty value (even a broken
# placeholder) OVERRIDES the working local default and breaks `docker compose up`.
# Empty here ⇒ the mesh falls back to postgresql://app_user:app_user@postgres:5432/lms
# (per-request runtime, RLS-enforced), postgresql://control_plane_user:control_plane_user@postgres:5432/lms
# (CONTROL_PLANE_DATABASE_URL — control-plane writes, RLS-subject) and
# postgresql://lms:lms@postgres:5432/lms (seed/migrate, privileged owner).
# Only set these to target Supabase/remote (see the opt-in block below).
DATABASE_URL=
MIGRATION_DATABASE_URL=
DIRECT_URL=
# CONTROL_PLANE_DATABASE_URL → control-plane writes (tenant registry / delegation /
# silo saga + the in-tx event_outbox row), the dedicated `control_plane_user` role.
# Distinct from the app_user runtime DATABASE_URL and the privileged owner
# MIGRATION_DATABASE_URL. Leave EMPTY locally to use the in-compose default.
CONTROL_PLANE_DATABASE_URL=

# Host-published port for the bundled in-compose Postgres (compose maps
# ${PG_PORT:-5432}:5432). Override (e.g. PG_PORT=5433) if you already run a local
# Postgres on 5432 so `docker compose up` doesn't collide with it.
PG_PORT=5432

# ── Database (Supabase / remote — opt-in) ────────────────────
# Uncomment + fill these ONLY when pointing the mesh at remote managed Postgres
# instead of the bundled in-compose Postgres.
#
# Two-role model (#286 / ADR-0026): the RUNTIME connection MUST use a dedicated
# least-privilege app role that is NOSUPERUSER NOBYPASSRLS and is NOT the table
# owner, so Postgres FORCE RLS is enforced (tenant isolation). The owner/migrator
# role (superuser/owner) is used ONLY for migrations + seeding, never at runtime.
# Pooled connection (Supavisor / PgBouncer) for serverless + IPv4 runtimes.
# The direct db.<ref>.supabase.co host is IPv6-only; use the pooler URL
# (aws-<n>-<region>.pooler.supabase.com:6543?pgbouncer=true) for IPv4.
#
# DATABASE_URL  → RUNTIME, point at the LEAST-PRIVILEGE app role (NOT postgres).
# DATABASE_URL=postgresql://app_user:password@aws-0-<region>.pooler.supabase.com:6543/postgres?pgbouncer=true&sslmode=require
# MIGRATION_DATABASE_URL → privileged owner/migrator role, used ONLY by the seed
# one-shot + migrations (db:apply / roles.sql).
# MIGRATION_DATABASE_URL=postgresql://postgres.<ref>:password@aws-0-<region>.pooler.supabase.com:5432/postgres?sslmode=require
# Direct connection for migrations (no pooler) — privileged role.
# DIRECT_URL=postgresql://postgres:password@db.<ref>.supabase.co:5432/postgres?sslmode=require
# Control-plane DB that holds the tenant registry / silo routing. Point at the
# dedicated LEAST-PRIVILEGE `control_plane_user` role (NOSUPERUSER NOBYPASSRLS,
# NOT postgres) — inject a strong, unique password in prod.
# CONTROL_PLANE_DATABASE_URL=postgresql://control_plane_user:password@aws-0-<region>.pooler.supabase.com:6543/postgres?pgbouncer=true&sslmode=require

# Silo provisioning (optional). Provision dedicated DBs/branches per tenant via
# your managed Postgres provider's API (e.g. Neon) when promoting to silo tier.
NEON_API_KEY=
NEON_PROJECT_ID=

# ── Auth / Security ──────────────────────────────────────────
JWT_SECRET=change-me-in-prod
JWT_ISSUER=https://auth.lms.example.com
JWT_AUDIENCE=lms-api
ACCESS_TOKEN_TTL=900
REFRESH_TOKEN_TTL=2592000
# External CIAM directory (do NOT build your own IdP). Use a managed provider
# strong on SAML/OIDC SSO for institutions, e.g. WorkOS / Auth0 / Clerk.
# The identity service maps external identities -> internal users + claims.
CIAM_PROVIDER=workos
CIAM_API_KEY=
CIAM_CLIENT_ID=
OIDC_ISSUER_URL=

# ── Object storage (Vercel Blob) ─────────────────────────────
BLOB_READ_WRITE_TOKEN=

# ── Cache / queue / messaging (Upstash — serverless) ─────────
# Redis: tenant-prefixed keys (t:{tenantId}:...), LTI nonce/state cache,
# unread counters. QStash: serverless message bus + scheduled jobs (replaces
# Service Bus / Azure Functions / Hangfire).
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=
QSTASH_TOKEN=
QSTASH_CURRENT_SIGNING_KEY=
QSTASH_NEXT_SIGNING_KEY=

# ── Gateway rate limiting ────────────────────────────────────
# Per-tenant request budget per fixed window. Backed by Upstash Redis when the
# creds above are set (shared across gateway instances), else an in-process
# limiter. Exceeding the budget returns 429 with a Retry-After header.
RATE_LIMIT_MAX=600
RATE_LIMIT_WINDOW_SECONDS=60

# ── LLM (Groq) — used by analytics/AI (Lumi-equivalent) features ──
GROQ_API_KEY=
GROQ_MODEL=llama-3.3-70b-versatile
# Max output tokens cap for the ai /chat completion — a cost/robustness bound.
GROQ_MAX_TOKENS=1024

# ── AI chat rate limiting + cost ceiling (#309) ──────────────
# The ai POST /courses/:courseId/chat endpoint enforces a per-tenant AND
# per-user request rate limit (Upstash-backed when its creds are set, else an
# in-process limiter), plus a durable per-tenant per-UTC-day usage ceiling that
# bounds Groq spend. Breaching a rate limit returns 429 rate_limited with a
# Retry-After header; reaching a daily ceiling returns 429 cost_exceeded without
# calling Groq.
# Per-tenant requests allowed per window.
AI_CHAT_RATE_LIMIT_MAX=120
# Per-user requests allowed per window (so one user can't drain the tenant).
AI_CHAT_USER_RATE_LIMIT_MAX=30
# Rate-limit window length in seconds (applies to both limits above).
AI_CHAT_RATE_LIMIT_WINDOW_SECONDS=60
# Max chat requests per tenant per UTC day (the durable, cross-replica ceiling).
AI_CHAT_DAILY_TENANT_REQUEST_CEILING=2000
# Max estimated output tokens per tenant per UTC day (0 = token ceiling off).
AI_CHAT_DAILY_TENANT_TOKEN_CEILING=0

# ── Observability / distributed tracing (OpenTelemetry, #83) ──
# Tracing is OFF by default and a complete no-op unless OTEL_ENABLED=true AND
# OTEL_EXPORTER_OTLP_ENDPOINT is set. The OTel SDK is preloaded into every
# service via NODE_OPTIONS=--require @lms/observability/register (docker-compose
# x-common-env). Spans are tagged with the opaque tenant id only — never user PII.
# Leave these empty for local/dev/CI: the mesh emits no spans and makes no
# outbound connections.
OTEL_ENABLED=false
OTEL_EXPORTER_OTLP_ENDPOINT=
OTEL_EXPORTER_OTLP_HEADERS=
OTEL_EXPORTER_OTLP_PROTOCOL=http/protobuf
# OTEL_SERVICE_NAME is set per-service by docker-compose (the service key); only
# set it here when running a single service standalone.
# OTEL_SERVICE_NAME=
#
# Example — Axiom (verify vendor specifics in current Axiom docs):
# OTEL_ENABLED=true
# OTEL_EXPORTER_OTLP_ENDPOINT=https://api.axiom.co
# OTEL_EXPORTER_OTLP_HEADERS=Authorization=Bearer xaat-<token>,X-Axiom-Dataset=<dataset>
# OTEL_EXPORTER_OTLP_PROTOCOL=http/protobuf
#
# Example — Grafana Cloud (verify vendor specifics in current Grafana docs):
# OTEL_ENABLED=true
# OTEL_EXPORTER_OTLP_ENDPOINT=https://otlp-gateway-<zone>.grafana.net/otlp
# OTEL_EXPORTER_OTLP_HEADERS=Authorization=Basic <base64(instanceID:apiToken)>
# OTEL_EXPORTER_OTLP_PROTOCOL=http/protobuf

# ── Service URLs (gateway routing; ports 4000-4026) ──────────
GATEWAY_URL=http://localhost:4000
IDENTITY_URL=http://localhost:4001
TENANT_URL=http://localhost:4002
USER_ORG_URL=http://localhost:4003
ENROLLMENT_URL=http://localhost:4004
COURSE_URL=http://localhost:4005
CONTENT_URL=http://localhost:4006
ASSIGNMENT_URL=http://localhost:4007
ASSESSMENT_URL=http://localhost:4008
GRADING_URL=http://localhost:4009
DISCUSSION_URL=http://localhost:4010
ANNOUNCEMENT_URL=http://localhost:4011
NOTIFICATION_URL=http://localhost:4012
CALENDAR_URL=http://localhost:4013
RUBRIC_URL=http://localhost:4014
ANALYTICS_URL=http://localhost:4015
REPORTING_URL=http://localhost:4016
AI_URL=http://localhost:4017
LTI_URL=http://localhost:4018
SIS_URL=http://localhost:4019
VIDEO_URL=http://localhost:4020
SEARCH_URL=http://localhost:4021
BILLING_URL=http://localhost:4022
AUDIT_URL=http://localhost:4023
MOBILE_BFF_URL=http://localhost:4024
ATTENDANCE_URL=http://localhost:4025
# relay is an outbox-publisher WORKER (not gateway-routed); it still serves a
# GET /health liveness endpoint on 4026. Its events upstream is set by compose as
# NOTIFICATION_EVENTS_URL=http://notification:4012/events.
RELAY_URL=http://localhost:4026

# ── Standards / Integrations (1EdTech) ───────────────────────
LTI_PLATFORM_ISSUER=https://lms.example.com
LTI_JWKS_URL=https://lms.example.com/.well-known/jwks.json
ONEROSTER_BASE_URL=https://lms.example.com/ims/oneroster/v1p2
CALIPER_ENDPOINT=https://lms.example.com/caliper/events
