{
  "name": "lms-saas",
  "version": "0.1.0",
  "private": true,
  "description": "Enterprise multi-tenant LMS microservices SaaS (D2L Brightspace-class) on GitHub + Vercel + serverless Postgres.",
  "packageManager": "pnpm@9.12.0",
  "engines": {
    "node": ">=20.0.0",
    "pnpm": ">=9.0.0"
  },
  "scripts": {
    "start": "docker compose up -d",
    "start:pull": "docker compose up -d",
    "build:base": "docker build -f docker/base.Dockerfile -t lms-base-deps:local .",
    "start:build": "pnpm build:base && docker compose -f docker-compose.yml -f docker-compose.build.yml up -d --build",
    "stop": "docker compose down",
    "down": "docker compose down",
    "down:clean": "docker compose down -v",
    "ps": "docker compose ps",
    "logs": "docker compose logs -f",
    "smoke": "node scripts/smoke.mjs",
    "build": "turbo run build",
    "dev": "turbo run dev",
    "lint": "turbo run lint",
    "test": "turbo run test",
    "typecheck": "turbo run typecheck",
    "check:rls": "node scripts/checks/check-rls.mjs",
    "check:commits": "node scripts/checks/check-commits.mjs",
    "check:handshake": "node scripts/checks/check-handshake.mjs",
    "check:rules": "pnpm check:rls && pnpm check:commits && pnpm check:handshake",
    "test:checks": "node --test scripts/checks/check.test.mjs",
    "format": "prettier --write \"**/*.{ts,tsx,js,jsx,json,md}\"",
    "format:check": "prettier --check \"**/*.{ts,tsx,js,jsx,json,md}\"",
    "db:generate": "pnpm --filter @lms/db generate",
    "db:migrate": "pnpm --filter @lms/db migrate:deploy",
    "db:migrate:dev": "pnpm --filter @lms/db migrate:dev",
    "db:seed": "pnpm --filter @lms/db seed",
    "db:check-drift": "node scripts/db/check-drift.mjs",
    "db:verify-rls": "node scripts/db/verify-rls.mjs",
    "clean": "turbo run clean && rimraf node_modules"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.0",
    "@lms/eslint-config": "workspace:*",
    "@types/node": "^20.14.0",
    "eslint": "^9.39.0",
    "pg": "^8.13.0",
    "prettier": "^3.3.3",
    "rimraf": "^6.0.1",
    "turbo": "^2.1.0",
    "typescript": "^5.5.4"
  }
}
